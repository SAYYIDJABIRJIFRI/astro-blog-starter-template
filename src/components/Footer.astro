---
const year = new Date().getFullYear();
const links = ['About', 'Venues', 'Gallery', 'Amenities', 'Contact'];
---
<footer class="footer" id="footer">
	<div class="footer-grid">
		<div>
			<a class="brand footer-brand" href="/"><span class="brand-mark">O</span><span><strong>Olive</strong><small>International</small></span></a>
			<p>Premium wedding hall, convention center, auditorium, reception venue, event hall, conference hall, and exhibition venue in Kerala.</p>
		</div>
		<div>
			<h3>Quick Links</h3>
			{links.map((link) => <a href={`#${link.toLowerCase()}`}>{link}</a>)}
		</div>
		<div>
			<h3>Social</h3>
			<a href="#contact">Instagram</a>
			<a href="#contact">Facebook</a>
			<a href="#contact">YouTube</a>
		</div>
		<div>
			<h3>Contact</h3>
			<p>Olive International Convention Center<br />Kerala, India</p>
			<a href="tel:+919876543210">+91 98765 43210</a>
			<a href="mailto:events@oliveinternational.com">events@oliveinternational.com</a>
		</div>
	</div>
	<div class="footer-bottom">
		<span>© {year} Olive International Convention Center. All rights reserved.</span>
		<span><a href="#privacy">Privacy Policy</a> · <a href="#terms">Terms & Conditions</a></span>
	</div>
</footer>
